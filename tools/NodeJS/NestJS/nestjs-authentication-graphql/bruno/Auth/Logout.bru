meta {
  name: Logout
  type: graphql
  seq: 4
}

post {
  url: {{graphqlUrl}}
  body: graphql
  auth: none
}

body:graphql {
  mutation AuthLogout {
    authLogout
  }
}

docs {
  GraphQL: `authLogout`. Прибирає cookies `accessToken` та `refreshToken` через `res.clearCookie`. Cookie Jar синхронізується лише якщо клієнт отримує `Set-Cookie` з того ж хосту.
}
